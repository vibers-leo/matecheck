<script>
  let current = 0;
  const total = 4;
  const wrapper = document.getElementById('slides-wrapper');
  const indicators = document.querySelectorAll('.indicator');
  const tabs = document.querySelectorAll('.screen-tab');

  function goTo(index) {
    current = index;
    wrapper.style.transform = `translateX(-${index * 100}%)`;
    indicators.forEach((el, i) => {
      el.classList.toggle('bg-emerald-500', i === index);
      el.classList.toggle('w-6', i === index);
      el.classList.toggle('bg-gray-200', i !== index);
      el.classList.toggle('w-2', i !== index);
    });
    tabs.forEach((el, i) => {
      el.classList.toggle('border-emerald-300', i === index);
      el.classList.toggle('border-gray-100', i !== index);
    });
  }

  indicators.forEach(el => el.addEventListener('click', () => goTo(+el.dataset.index)));
  tabs.forEach(el => el.addEventListener('click', () => goTo(+el.dataset.screen)));

  // 자동 슬라이드
  setInterval(() => goTo((current + 1) % total), 3000);

  // 스와이프
  let startX = 0;
  const screen = document.getElementById('phone-screen');
  screen.addEventListener('touchstart', e => startX = e.touches[0].clientX);
  screen.addEventListener('touchend', e => {
    const diff = startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) goTo(diff > 0 ? Math.min(current+1, total-1) : Math.max(current-1, 0));
  });
</script>
